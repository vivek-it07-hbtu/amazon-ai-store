# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/amazon_clone
MONGODB_TEST_URI=mongodb://localhost:27017/amazon_clone_test

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=amazon_users
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# Stripe Payment
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Python Service
PYTHON_SERVICE_URL=http://localhost:8000

# C++ Service
CPP_SERVICE_PORT=9000

# AWS S3 (Optional for image storage)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=amazon-clone-images

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password

# Client URL
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_CLIENT_URL=http://localhost:3000
