{
  "name": "amazon-clone",
  "version": "1.0.0",
  "description": "Full-stack Amazon Clone with Next.js, Express, MongoDB, PostgreSQL",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:next\" \"npm run dev:server\"",
    "dev:next": "next dev",
    "dev:server": "nodemon server/index.js",
    "dev:python": "python services/recommendation_service.py",
    "build": "next build",
    "build:cpp": "g++ -o bin/search_engine services/cpp/search_engine.cpp -std=c++17",
    "start": "node server/index.js",
    "lint": "next lint",
    "test": "jest"
  },
  "dependencies": {
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "express": "^4.18.2",
    "mongoose": "^8.0.0",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.35.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "axios": "^1.6.0",
    "stripe": "^14.0.0",
    "multer": "^1.4.5-lts.1",
    "redis": "^4.6.11",
    "socket.io": "^4.6.0",
    "socket.io-client": "^4.6.0",
    "@reduxjs/toolkit": "^2.0.0",
    "react-redux": "^9.0.0",
    "framer-motion": "^10.16.0",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^4.12.0",
    "tailwindcss": "^3.3.5",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.31"
  },
  "devDependencies": {
    "@types/node": "^20.9.0",
    "@types/react": "^18.2.37",
    "@types/express": "^4.17.21",
    "typescript": "^5.2.2",
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.2",
    "eslint": "^8.53.0",
    "eslint-config-next": "^14.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
